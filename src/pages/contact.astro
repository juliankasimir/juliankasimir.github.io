---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="Kontakt">
  <PageHeader title="Kontakt" subtitle="Schreib mir gerne – am liebsten direkt auf LinkedIn." bgType="gradient" />
  <section class="my-24">
    <div class="container">
      <div class="mx-auto max-w-xl space-content">
        <Heading level="h2">So erreichst du mich</Heading>
        <p class="text-xl">
          Kein Formular, kein Bot-Filter. Schreib mir einfach direkt auf einem der Kanäle – oder zeig dir meine
          E-Mail-Adresse an.
        </p>

        <div class="flex flex-col gap-4">
          <Link
            href="https://www.linkedin.com/in/juliankasimir"
            isButton
            isExternal
            type="primary"
            animateOnHover
            animationType="boop"
          >
            <Icon aria-hidden="true" name="lucide:linkedin" size={20} />
            LinkedIn
          </Link>
          <button
            id="reveal-email-btn"
            type="button"
            aria-expanded="false"
            aria-controls="email-reveal"
          >
            <Icon aria-hidden="true" name="lucide:mail" size={20} />
            E-Mail-Adresse anzeigen
          </button>
          <a id="email-reveal" class="hidden" aria-live="polite"></a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

<script>
  const btn = document.getElementById('reveal-email-btn')
  const target = document.getElementById('email-reveal') as HTMLAnchorElement | null

  // Adresse verschleiert: zusammengebaut per JS, nie im HTML sichtbar
  const parts = ['julian', '.kasimir', '@', 'gmail', '.com']

  btn?.addEventListener('click', () => {
    const email = parts.join('')
    if (target) {
      target.href = `mailto:${email}`
      target.textContent = email
      target.classList.remove('hidden')
    }
    btn.setAttribute('aria-expanded', 'true')
    btn.classList.add('hidden')
  })
</script>
