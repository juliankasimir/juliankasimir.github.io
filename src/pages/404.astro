---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading, Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
---

<DefaultLayout title="404">
  <section class="my-12">
    <div class="container">
      <Heading level="h1">404</Heading>
    </div>
  </section>
  <section class="my-12">
    <div class="space-content container">
      <p class="text-2xl">World not found. Die Seite existiert nicht – aber das Ende der Welt wartet auch nicht.</p>
      <img
        src="/projects/drehbuch-12-min-mood-cover.webp"
        alt="Mood-Cover aus dem Projekt Drehbuch 12 Min"
        width="768"
        height="768"
        loading="lazy"
        style="border-radius: 0.5rem; border: 2px solid var(--color-primary-200, #eee); max-width: min(100%, 28rem); height: auto;"
      />
      <Link href="/" isButton type="secondary" animateOnHover animationType="nudge">
        Zurück nach Hause
        <Icon aria-hidden="true" name="lucide:rocket" size="1.5rem" />
      </Link>
    </div>
  </section>
</DefaultLayout>
