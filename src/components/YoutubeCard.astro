---
interface Props {
  videoId: string
  title: string
  thumbnail: string
}

const { videoId, title, thumbnail } = Astro.props
const youtubeUrl = `https://www.youtube.com/watch?v=${videoId}`
---

<div class="youtube-card">
  <a href={youtubeUrl} target="_blank" rel="noopener noreferrer" aria-label={`${title} auf YouTube ansehen (öffnet in neuem Tab)`}>
    <div class="thumbnail-wrapper">
      <img src={thumbnail} alt={`Vorschaubild: ${title}`} width="1280" height="720" loading="lazy" />
      <div class="play-overlay" aria-hidden="true">
        <svg viewBox="0 0 68 48" width="68" height="48">
          <path d="M66.5 7.7c-.8-2.9-3-5.2-5.9-6C55.8 0 34 0 34 0S12.2 0 7.4 1.7c-2.9.8-5.1 3.1-5.9 6C0 12.5 0 24 0 24s0 11.5 1.5 16.3c.8 2.9 3 5.2 5.9 6C12.2 48 34 48 34 48s21.8 0 26.6-1.7c2.9-.8 5.1-3.1 5.9-6C68 35.5 68 24 68 24s0-11.5-1.5-16.3z" fill="#ff0000"/>
          <path d="M45 24 27 14v20" fill="#fff"/>
        </svg>
      </div>
    </div>
    <p class="video-label">
      <span>{title}</span>
      <span class="external-hint">↗ YouTube</span>
    </p>
  </a>
  <p class="dsgvo-note">
    Kein Tracking – das Video wird nicht eingebettet. Beim Klick öffnet sich YouTube in einem neuen Tab.
  </p>
</div>

<style>
  .youtube-card {
    margin-block: 2rem;
  }

  .youtube-card a {
    display: block;
    text-decoration: none;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 2px solid var(--color-primary-200, #eee);
    transition: border-color 0.2s;
  }

  .youtube-card a:hover,
  .youtube-card a:focus-visible {
    border-color: var(--brand-primary);
  }

  .thumbnail-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #000;
  }

  .thumbnail-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.2s;
  }

  .youtube-card a:hover .thumbnail-wrapper img,
  .youtube-card a:focus-visible .thumbnail-wrapper img {
    opacity: 0.85;
  }

  .play-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  .play-overlay svg {
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.5));
  }

  .video-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    font-weight: 600;
    color: #1a1a1a;
    background: var(--color-primary-100, #f0ece4);
    margin: 0;
  }

  .external-hint {
    font-size: 0.85em;
    opacity: 0.7;
    font-weight: 400;
  }

  .dsgvo-note {
    font-size: 0.8rem;
    opacity: 0.6;
    margin-block-start: 0.5rem;
    margin-inline: 0.25rem;
  }
</style>
