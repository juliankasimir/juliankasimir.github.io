---
import Logo from './Logo.astro'
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

const currentYear = new Date().getFullYear()
---

<footer>
  <section class="py-20">
    <div class="container">
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3">

        <div class="flex flex-col gap-4">
          <Logo loading="lazy" noLink />
          <p class="text-sm leading-relaxed">
            Persönliche Seite von Julian Kasimir. Projekte, Ideen und alles, was mich beschäftigt.
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <p class="font-semibold">Kontakt</p>
          <ul class="flex flex-col gap-3">
            <li>
              <Link isExternal href="https://github.com/juliankasimir" hideIcon>
                <Icon aria-hidden="true" name="lucide:github" size={18} class="inline-block align-middle me-2" />
                GitHub
              </Link>
            </li>
            <li>
              <Link isExternal href="https://www.linkedin.com/in/juliankasimir" hideIcon>
                <Icon aria-hidden="true" name="lucide:linkedin" size={18} class="inline-block align-middle me-2" />
                LinkedIn
              </Link>
            </li>
            <li>
              <button id="footer-reveal-email-btn" type="button" class="flex items-center gap-2 underline-offset-4 hover:underline">
                <Icon aria-hidden="true" name="lucide:mail" size={18} />
                E-Mail anzeigen
              </button>
              <span id="footer-email-reveal" class="hidden" aria-live="polite"></span>
            </li>
          </ul>
        </div>

        <div class="flex flex-col gap-4">
          <p class="font-semibold">Rechtliches</p>
          <ul class="flex flex-col gap-3">
            <li><Link href="/impressum">Impressum</Link></li>
            <li><Link href="/datenschutz">Datenschutz</Link></li>
            <li><Link href="/agb">AGB</Link></li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <section class="py-6 border-t border-[var(--border-color-subtle)]">
    <div class="container flex flex-col gap-2 text-sm md:flex-row md:justify-between">
      <p>&copy; {currentYear} Julian Kasimir</p>
    </div>
  </section>
</footer>

<script>
  const btn = document.getElementById('footer-reveal-email-btn')
  const target = document.getElementById('footer-email-reveal')
  const parts = ['mail', '@', 'juliankasimir', '.de']

  btn?.addEventListener('click', () => {
    const email = parts.join('')
    if (target) {
      target.innerHTML = `<a href="mailto:${email}" class="underline">${email}</a>`
      target.classList.remove('hidden')
    }
    btn.classList.add('hidden')
  })
</script>
