---
import { Link } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

/**
 * Hero Component
 *
 * @description A component that displays a hero section with a title, description, and image
 */
interface Props {
  /**
   * The source URL for the profile image
   */
  imageSrc?: string
} 
 
const { imageSrc = '/profil.webp' }: Props = Astro.props
---

<section class="hero my-24">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-24 lg:grid-cols-2">
      <div class="flex flex-col items-center gap-8 md:items-start">
        <h1 class="text-center text-6xl md:text-left lg:text-8xl">
          <slot><span class="text-gradient">Hello World,</span> ich bin Julian.</slot>
        </h1>
        <p class="max-w-2xl text-center text-2xl md:text-left">
         Irgendwo zwischen Hessen und Stuttgart groß geworden. Vater &amp; Ideenentwickler. Seit 2004 im Frontend unterwegs. Diese Seite ist mein persönlicher Raum. Für alles Technische gibt es <a href="https://jolution.de" target="_blank" rel="noopener noreferrer" class="underline">Jolution</a>.
        </p>
        <div class="hero-actions flex flex-col gap-3 min-[500px]:flex-row">
          <Link
            href="https://github.com/juliankasimir"
            isButton
            type="primary"
            animateOnHover
            animationType="boop"
          >
            <Icon aria-hidden="true" name="lucide:star" size="1.5rem" />
            GitHub Profil
          </Link>
          <Link
            href="https://www.linkedin.com/in/juliankasimir/"
            isExternal
            isButton
            type="secondary"
            animateOnHover
            animationType="boop"
          >
            <Icon aria-hidden="true" name="lucide:linkedin" size="1.5rem" />
            LinkedIn
          </Link>
        </div>
      </div>
      <div class="hero-media hidden lg:block">
        <img class="w-full max-w-full" src={imageSrc} alt="Portraet von Julian" loading="eager" />
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  h1 {
    text-wrap: unset;
  }

  .hero-media {
    img {
      block-size: auto;
      inline-size: min(960px, 100%);
      max-inline-size: 100%;
    }
  }

  .text-gradient {
    background: linear-gradient(
      315deg,
      light-dark(var(--color-primary-300), var(--color-secondary-100)) 25%,
      light-dark(var(--color-secondary-300), var(--color-primary-200))
    );
    background-clip: border-box;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
